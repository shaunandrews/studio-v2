{
  "name": "Launchpad",
  "description": "A SaaS developer platform landing page",
  "favicon": "🚀",
  "theme": {
    "colors": {
      "bg": "#fff",
      "text": "#1a1a1a",
      "accent": "#2563eb",
      "muted": "#666",
      "border": "rgba(0,0,0,0.06)",
      "surface": "#fafafa"
    },
    "fonts": {
      "heading": "'Inter', sans-serif",
      "body": "'Inter', sans-serif"
    },
    "fontSizes": {
      "small": "0.875rem",
      "medium": "1rem",
      "large": "1.25rem",
      "x-large": "2rem",
      "xx-large": "3rem"
    },
    "fontWeights": {
      "regular": 400,
      "medium": 500,
      "bold": 700
    },
    "lineHeights": {
      "tight": 1.15,
      "normal": 1.5,
      "relaxed": 1.7
    },
    "spacing": {
      "xs": "0.5rem",
      "s": "0.75rem",
      "m": "1.25rem",
      "l": "2rem",
      "xl": "3rem",
      "xxl": "5rem"
    },
    "radii": {
      "small": "6px",
      "medium": "10px",
      "large": "16px",
      "full": "9999px"
    },
    "layout": {
      "content": "680px",
      "wide": "1000px"
    }
  },
  "parts": ["header", "footer"],
  "pages": [
    { "slug": "/", "title": "Home", "template": "home", "wpTemplate": "front-page" },
    { "slug": "/features", "title": "Features", "template": "features", "wpTemplate": "page-features" },
    { "slug": "/pricing", "title": "Pricing", "template": "pricing", "wpTemplate": "page-pricing" },
    { "slug": "/about", "title": "About", "template": "about", "wpTemplate": "page" },
    { "slug": "/contact", "title": "Contact", "template": "contact", "wpTemplate": "page" }
  ],
  "wpTemplates": [
    { "slug": "front-page", "label": "Front Page", "renders": ["/"] },
    { "slug": "page", "label": "Page", "renders": ["/about", "/contact"] },
    { "slug": "page-features", "label": "Features Page", "renders": ["/features"] },
    { "slug": "page-pricing", "label": "Pricing Page", "renders": ["/pricing"] },
    { "slug": "index", "label": "Index" },
    { "slug": "404", "label": "404" },
    { "slug": "search", "label": "Search Results" }
  ]
}
