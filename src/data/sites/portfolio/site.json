{
  "name": "Studio Meridian",
  "description": "A dark-themed design agency portfolio",
  "favicon": "\u25c6",
  "theme": {
    "colors": {
      "bg": "#111",
      "text": "#fff",
      "accent": "#fff",
      "muted": "rgba(255,255,255,0.5)",
      "border": "rgba(255,255,255,0.08)",
      "surface": "#1a1a1a"
    },
    "fonts": {
      "heading": "'Inter', sans-serif",
      "body": "'Inter', sans-serif"
    },
    "fontSizes": {
      "small": "0.875rem",
      "medium": "1rem",
      "large": "1.25rem",
      "x-large": "2rem",
      "xx-large": "3.5rem"
    },
    "fontWeights": {
      "regular": 400,
      "medium": 500,
      "bold": 600
    },
    "lineHeights": {
      "tight": 1.1,
      "normal": 1.5,
      "relaxed": 1.7
    },
    "spacing": {
      "xs": "0.5rem",
      "s": "1rem",
      "m": "1.5rem",
      "l": "2.5rem",
      "xl": "4rem",
      "xxl": "6rem"
    },
    "radii": {
      "small": "2px",
      "medium": "4px",
      "large": "8px",
      "full": "9999px"
    },
    "layout": {
      "content": "680px",
      "wide": "1000px"
    }
  },
  "parts": ["header", "footer"],
  "pages": [
    { "slug": "/", "title": "Home", "template": "home", "wpTemplate": "front-page" },
    {
      "slug": "/work", "title": "Work", "template": "work", "wpTemplate": "archive",
      "collection": { "slug": "/work/:slug", "title": "Project", "template": "project", "wpTemplate": "single", "count": 8 }
    },
    { "slug": "/services", "title": "Services", "template": "services", "wpTemplate": "page" },
    { "slug": "/about", "title": "About", "template": "about", "wpTemplate": "page" },
    { "slug": "/contact", "title": "Contact", "template": "contact", "wpTemplate": "page" }
  ],
  "wpTemplates": [
    { "slug": "front-page", "label": "Front Page", "renders": ["/"] },
    { "slug": "page", "label": "Page", "renders": ["/services", "/about", "/contact"] },
    { "slug": "archive", "label": "Archive", "renders": ["/work"] },
    { "slug": "single", "label": "Single Project" },
    { "slug": "index", "label": "Index" },
    { "slug": "404", "label": "404" },
    { "slug": "search", "label": "Search Results" }
  ]
}
