{
  "name": "Arlo Writes",
  "description": "A personal blog about design and engineering",
  "favicon": "\u270d\ufe0f",
  "theme": {
    "colors": {
      "bg": "#fff",
      "text": "#1a1a1a",
      "accent": "#1a1a1a",
      "muted": "#999",
      "border": "rgba(0,0,0,0.06)",
      "surface": "#f0f0f0"
    },
    "fonts": {
      "heading": "'Inter', sans-serif",
      "body": "'Inter', sans-serif"
    },
    "spacing": {
      "content": "640px",
      "wide": "960px"
    }
  },
  "parts": ["header", "footer"],
  "pages": [
    { "slug": "/", "title": "Home", "template": "home", "wpTemplate": "front-page" },
    {
      "slug": "/blog", "title": "Articles", "template": "blog", "wpTemplate": "archive",
      "collection": { "slug": "/blog/:slug", "title": "Post", "template": "post", "wpTemplate": "single", "count": 36 }
    },
    { "slug": "/about", "title": "About", "template": "about", "wpTemplate": "page" },
    { "slug": "/contact", "title": "Contact", "template": "contact", "wpTemplate": "page" }
  ],
  "wpTemplates": [
    { "slug": "front-page", "label": "Front Page", "renders": ["/"] },
    { "slug": "page", "label": "Page", "renders": ["/about", "/contact"] },
    { "slug": "archive", "label": "Archive", "renders": ["/blog"] },
    { "slug": "single", "label": "Single Post" },
    { "slug": "404", "label": "Not Found" },
    { "slug": "search", "label": "Search Results" }
  ]
}
