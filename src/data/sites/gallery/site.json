{
  "name": "Wild Lens",
  "description": "A nature and landscape photography portfolio",
  "favicon": "📷",
  "theme": {
    "colors": {
      "bg": "#111",
      "text": "#fff",
      "accent": "#fff",
      "muted": "rgba(255,255,255,0.5)",
      "border": "rgba(255,255,255,0.06)",
      "surface": "#1a1a1a"
    },
    "fonts": {
      "heading": "'Inter', sans-serif",
      "body": "'Inter', sans-serif"
    },
    "fontSizes": {
      "small": "0.8125rem",
      "medium": "0.9375rem",
      "large": "1.125rem",
      "x-large": "1.75rem",
      "xx-large": "3rem"
    },
    "fontWeights": {
      "regular": 300,
      "medium": 400,
      "bold": 600
    },
    "lineHeights": {
      "tight": 1.1,
      "normal": 1.5,
      "relaxed": 1.7
    },
    "spacing": {
      "xs": "0.5rem",
      "s": "1rem",
      "m": "1.5rem",
      "l": "2.5rem",
      "xl": "4rem",
      "xxl": "6rem"
    },
    "radii": {
      "small": "0",
      "medium": "2px",
      "large": "4px",
      "full": "9999px"
    },
    "layout": {
      "content": "680px",
      "wide": "1000px"
    }
  },
  "parts": ["header", "footer"],
  "pages": [
    { "slug": "/", "title": "Home", "template": "home", "wpTemplate": "front-page" },
    {
      "slug": "/portfolio", "title": "Portfolio", "template": "gallery", "wpTemplate": "archive",
      "collection": { "slug": "/portfolio/:slug", "title": "Album", "template": "album", "wpTemplate": "single", "count": 15 }
    },
    { "slug": "/about", "title": "About", "template": "about", "wpTemplate": "page" },
    { "slug": "/contact", "title": "Contact", "template": "contact", "wpTemplate": "page" }
  ],
  "wpTemplates": [
    { "slug": "front-page", "label": "Front Page", "renders": ["/"] },
    { "slug": "page", "label": "Page", "renders": ["/about", "/contact"] },
    { "slug": "archive", "label": "Archive", "renders": ["/portfolio"] },
    { "slug": "single", "label": "Single Album" },
    { "slug": "index", "label": "Index" },
    { "slug": "404", "label": "404" },
    { "slug": "search", "label": "Search Results" }
  ]
}
