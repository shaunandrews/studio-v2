{
  "name": "Thread & Co.",
  "description": "A clean, modern e-commerce store",
  "favicon": "🧵",
  "theme": {
    "colors": {
      "bg": "#fff",
      "text": "#1a1a1a",
      "accent": "#1a1a1a",
      "muted": "#888",
      "border": "rgba(0,0,0,0.08)",
      "surface": "#f8f8f8"
    },
    "fonts": {
      "heading": "'Inter', sans-serif",
      "body": "'Inter', sans-serif"
    },
    "spacing": {
      "content": "680px",
      "wide": "1000px"
    }
  },
  "parts": ["header", "footer"],
  "pages": [
    { "slug": "/", "title": "Home", "template": "home", "wpTemplate": "front-page" },
    { "slug": "/shop", "title": "Shop", "template": "shop", "wpTemplate": "archive-product" },
    {
      "slug": "/products", "title": "Products", "template": "product", "wpTemplate": "archive-product",
      "collection": { "slug": "/products/:slug", "title": "Product", "template": "product", "wpTemplate": "single-product", "count": 24 }
    },
    { "slug": "/cart", "title": "Cart", "template": "cart", "wpTemplate": "page-cart" },
    { "slug": "/about", "title": "About", "template": "about", "wpTemplate": "page" },
    { "slug": "/contact", "title": "Contact", "template": "contact", "wpTemplate": "page" }
  ],
  "wpTemplates": [
    { "slug": "front-page", "label": "Front Page", "renders": ["/"] },
    { "slug": "page", "label": "Page", "renders": ["/about", "/contact"] },
    { "slug": "page-cart", "label": "Cart Page", "renders": ["/cart"] },
    { "slug": "archive-product", "label": "Product Archive", "renders": ["/shop", "/products"] },
    { "slug": "single-product", "label": "Single Product" },
    { "slug": "404", "label": "Not Found" },
    { "slug": "search", "label": "Search Results" }
  ]
}
