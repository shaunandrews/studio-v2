{
  "name": "DevRef Docs",
  "description": "API reference documentation site",
  "favicon": "📘",
  "theme": {
    "colors": {
      "bg": "#fff",
      "text": "#1a1a1a",
      "accent": "#2563eb",
      "muted": "#666",
      "border": "rgba(0,0,0,0.08)",
      "surface": "#f8fafc"
    },
    "fonts": {
      "heading": "'Inter', sans-serif",
      "body": "'Inter', sans-serif"
    },
    "spacing": {
      "content": "680px",
      "wide": "1000px"
    }
  },
  "parts": ["header", "footer"],
  "pages": [
    { "slug": "/", "title": "Home", "template": "home", "wpTemplate": "front-page" },
    {
      "slug": "/docs", "title": "Docs", "template": "docs", "wpTemplate": "archive-docs",
      "collection": { "slug": "/docs/:slug", "title": "Article", "template": "docs", "wpTemplate": "single-docs", "count": 42 }
    },
    {
      "slug": "/blog", "title": "Blog", "template": "blog", "wpTemplate": "archive",
      "collection": { "slug": "/blog/:slug", "title": "Post", "template": "post", "wpTemplate": "single", "count": 10 }
    },
    { "slug": "/about", "title": "About", "template": "about", "wpTemplate": "page" }
  ],
  "wpTemplates": [
    { "slug": "front-page", "label": "Front Page", "renders": ["/"] },
    { "slug": "page", "label": "Page", "renders": ["/about"] },
    { "slug": "archive-docs", "label": "Docs Archive", "renders": ["/docs"] },
    { "slug": "single-docs", "label": "Single Doc" },
    { "slug": "archive", "label": "Archive", "renders": ["/blog"] },
    { "slug": "single", "label": "Single Post" },
    { "slug": "404", "label": "Not Found" },
    { "slug": "search", "label": "Search Results" }
  ]
}
