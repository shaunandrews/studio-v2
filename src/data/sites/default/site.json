{
  "name": "My WordPress Site",
  "description": "A simple, classic WordPress blog",
  "favicon": "📝",
  "theme": {
    "colors": {
      "bg": "#fff",
      "text": "#1a1a1a",
      "accent": "#1a1a1a",
      "muted": "#999",
      "border": "rgba(0,0,0,0.06)",
      "surface": "#fafafa"
    },
    "fonts": {
      "heading": "'Inter', sans-serif",
      "body": "'Inter', sans-serif"
    },
    "spacing": {
      "content": "640px",
      "wide": "800px"
    }
  },
  "parts": ["header", "footer"],
  "pages": [
    { "slug": "/", "title": "Home", "template": "home" },
    { "slug": "/about", "title": "About", "template": "about" },
    {
      "slug": "/blog", "title": "Blog", "template": "blog",
      "collection": { "slug": "/blog/:slug", "title": "Post", "template": "post", "count": 5 }
    },
    { "slug": "/contact", "title": "Contact", "template": "contact" }
  ]
}
